# CogniStream Backend Environment Variables
# Copy this file to .env and fill in your values

# Mistral AI API Key (for LLM-based matching)
MISTRAL_API_KEY=your_mistral_api_key_here

# Groq API Key (alternative LLM provider)
GROQ_API_KEY=your_groq_api_key_here

# Weights & Biases API Key (for ML experiment tracking)
WANDB_API_KEY=your_wandb_api_key_here

# Hugging Face Token (for model downloads)
HF_TOKEN=your_huggingface_token_here

# Skip LLM for faster testing (set to 1 to skip)
TRIALMATCH_SKIP_LLM=0
