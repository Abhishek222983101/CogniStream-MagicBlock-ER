            ],
            "type": "i64"
          },
          {
            "name": "is_revoked",
            "docs": [
              "Whether consent has been revoked"
            ],
            "type": "bool"
          },
          {
            "name": "revoked_at",
            "docs": [
              "Unix timestamp when consent was revoked (0 if not revoked)"
            ],
            "type": "i64"
          },
          {
            "name": "bump",
            "docs": [
