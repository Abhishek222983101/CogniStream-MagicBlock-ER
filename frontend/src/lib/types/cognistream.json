        "Seeds: [b\"consent\", patient_record.key(), trial_id.as_bytes()]"
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "patient_record",
            "docs": [
              "Reference to the patient record PDA"
